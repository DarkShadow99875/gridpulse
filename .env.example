# ============================================
# GridPulse - Environment Variables
# Copia questo file in .env e personalizza i valori
# ============================================

# ============================================
# DATABASE - LOCALE (usato con profilo "local")
# ============================================
DB_HOST=localhost
DB_PORT=5433
DB_NAME=gridpulse
DB_USER=gridpulse
DB_PASSWORD=gridpulse_dev

# URL completa (opzionale - ha precedenza sulle variabili sopra)
# DB_URL=jdbc:postgresql://localhost:5432/gridpulse

# ============================================
# DATABASE - PRODUZIONE (usato con profilo "prod")
# ============================================
# PROD_DB_HOST=tuo-db.prod.internal
# PROD_DB_PORT=5432
# PROD_DB_NAME=gridpulse
# PROD_DB_USER=gridpulse_app
# PROD_DB_PASSWORD=INSERISCI_PASSWORD_SICURA

# PROD_DB_URL=jdbc:postgresql://... (opzionale)

# ============================================
# APPLICAZIONE
# ============================================
SERVER_PORT=8080

# Livello di log (INFO, DEBUG, WARN)
LOG_LEVEL=INFO

# Per produzione imposta su "prod"
# SPRING_PROFILES_ACTIVE=local   # oppure "prod" o "h2"
